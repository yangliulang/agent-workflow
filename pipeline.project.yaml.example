# 项目绑定模板 — 复制为 pipeline.project.yaml 并按仓库结构调整

project:
  name: my-app
  prd:
    primary: handoff/product/prd.md
  onboarding:
    commander: handoff/pipeline/COMMANDER.md
    # greenfield=从0 | brownfield=存量首次接入 | continuing=续写迭代
    mode: greenfield

product:
  inventory: handoff/product/inventory.md
  backlog: handoff/product/backlog.yaml

features:
  root: handoff/features

roadmap:
  glob: handoff/roadmap/phase-*.md
  default_phase_file: handoff/roadmap/phase-1.md
  active_phase: 1
  phase_capacity: 0

apps:
  backend:
    path: apps/api
    stack: express
    dev:
      command: "cd apps/api && npm run dev"
      base_url: http://localhost:3000/api
      cors_origin: http://localhost:5173
  frontend:
    path: apps/web
    stack: vite-react
    dev:
      command: "cd apps/web && npm run dev"
      base_url: http://localhost:5173

conventions:
  api_response:
    success_code: 0

pipeline:
  hooks:
    enabled: true
    remind_on_write: true   # 写入 status.yaml 后注入下一条 Skill（每推进一次提醒一次）
    stop_followup: false    # true 时 stop 跟 followup_message，易与同 Chat「勿推进」空转
    require_new_chat: true
